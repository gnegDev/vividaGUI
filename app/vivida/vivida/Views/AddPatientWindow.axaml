<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:vivida.ViewModels"
        x:Class="vivida.Views.AddPatientWindow"
        x:DataType="vm:AddPatientViewModel"
        Title="Данные пациента"
        Width="580" Height="720"
        CanResize="True" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel>
        <!-- Кнопки снизу -->
        <Border DockPanel.Dock="Bottom" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Сохранить" Command="{Binding SaveCommand}"
                        Classes="accent"/>
                <Button Content="Отмена" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Border>

        <!-- Прокручиваемая форма -->
        <ScrollViewer Padding="4,0">
            <StackPanel Margin="12,8,12,8" Spacing="4">

                <!-- Обязательные поля -->
                <TextBlock Text="Обязательные поля" FontWeight="SemiBold" FontSize="13"
                           Margin="0,4,0,4" Foreground="#1a73e8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,8">
                    <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          VerticalAlignment="Top">
                        <Grid.Styles>
                            <Style Selector="TextBlock.label">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,8,8"/>
                            </Style>
                            <Style Selector="TextBox">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                            <Style Selector="NumericUpDown">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                            <Style Selector="ComboBox">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </Grid.Styles>

                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Имя пациента:"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Name}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Возраст (0–120):"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding Age}"
                                       Minimum="0" Maximum="120"
                                       Increment="1" FormatString="0.#"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Размер опухоли, см³:"/>
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding TumorSize}"
                                       Minimum="0" Maximum="100"
                                       Increment="0.1" FormatString="0.##"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Шкала Карновского (0–100):"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                       Value="{Binding Kps}"
                                       Minimum="0" Maximum="100"
                                       Increment="5" FormatString="0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Тип лечения:"/>
                        <ComboBox  Grid.Row="4" Grid.Column="1"
                                   ItemsSource="{Binding TreatmentOptions}"
                                   SelectedIndex="{Binding TreatmentIndex}"/>
                    </Grid>
                </Border>

                <!-- Дозировки -->
                <TextBlock Text="Дозировки (опционально)" FontWeight="SemiBold" FontSize="13"
                           Margin="0,8,0,4" Foreground="#1a73e8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,8">
                    <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,Auto,Auto,Auto">
                        <Grid.Styles>
                            <Style Selector="TextBlock.label">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,8,8"/>
                            </Style>
                            <Style Selector="NumericUpDown">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                        </Grid.Styles>

                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Доза химио, мг/м²:"/>
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding DoseMgPerM2}"
                                       Minimum="0" Maximum="1000"
                                       Increment="10" FormatString="0.#"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Циклы химиотерапии:"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding Cycles}"
                                       Minimum="0" Maximum="100"
                                       Increment="1" FormatString="0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Доза облучения, Гр:"/>
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding TotalDoseGy}"
                                       Minimum="0" Maximum="1000"
                                       Increment="0.5" FormatString="0.#"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Количество фракций:"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                       Value="{Binding Fractions}"
                                       Minimum="0" Maximum="100"
                                       Increment="1" FormatString="0"/>
                    </Grid>
                </Border>

                <!-- Генетические маркеры -->
                <TextBlock Text="Генетические маркеры (опционально)" FontWeight="SemiBold" FontSize="13"
                           Margin="0,8,0,4" Foreground="#1a73e8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,8">
                    <StackPanel Spacing="4">
                        <CheckBox Content="Метилирование MGMT" IsChecked="{Binding MgmtMethylation}"/>
                        <CheckBox Content="Мутация IDH" IsChecked="{Binding IdhMutation}"/>
                        <CheckBox Content="Амплификация EGFR" IsChecked="{Binding EgfrAmplification}"/>
                        <CheckBox Content="Мутация TERT" IsChecked="{Binding TertMutation}"/>
                        <CheckBox Content="Мутация ATRX" IsChecked="{Binding AtrxMutation}"/>
                    </StackPanel>
                </Border>

                <!-- Клинические признаки -->
                <TextBlock Text="Клинические признаки (опционально)" FontWeight="SemiBold" FontSize="13"
                           Margin="0,8,0,4" Foreground="#1a73e8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,8">
                    <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,Auto,Auto">
                        <Grid.Styles>
                            <Style Selector="TextBlock.label">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,8,8"/>
                            </Style>
                            <Style Selector="NumericUpDown">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                        </Grid.Styles>

                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Объём отёка, см³:"/>
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding EdemaVolume}"
                                       Minimum="0" Maximum="100"
                                       Increment="0.1" FormatString="0.##"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Доза стероидов, мг:"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding SteroidDose}"
                                       Minimum="0" Maximum="1000"
                                       Increment="0.5" FormatString="0.#"/>

                        <CheckBox  Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="Противосудорожные препараты"
                                   IsChecked="{Binding AntiseizureMeds}" Margin="0,0,0,4"/>
                    </Grid>
                </Border>

                <!-- Неврологические симптомы -->
                <TextBlock Text="Неврологические симптомы (опционально)" FontWeight="SemiBold" FontSize="13"
                           Margin="0,8,0,4" Foreground="#1a73e8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,8">
                    <StackPanel Spacing="4">
                        <CheckBox Content="Головная боль" IsChecked="{Binding HasHeadache}"/>
                        <CheckBox Content="Судороги" IsChecked="{Binding HasSeizures}"/>
                        <CheckBox Content="Двигательный дефицит" IsChecked="{Binding HasMotorDeficit}"/>
                        <CheckBox Content="Сенсорный дефицит" IsChecked="{Binding HasSensoryDeficit}"/>
                        <CheckBox Content="Когнитивные нарушения" IsChecked="{Binding HasCognitiveDecline}"/>
                        <CheckBox Content="Речевые нарушения" IsChecked="{Binding HasSpeechDisturbance}"/>
                        <CheckBox Content="Зрительные нарушения" IsChecked="{Binding HasVisualDisturbance}"/>
                    </StackPanel>
                </Border>

                <!-- Прочее -->
                <TextBlock Text="Прочее (опционально)" FontWeight="SemiBold" FontSize="13"
                           Margin="0,8,0,4" Foreground="#1a73e8"/>
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10,8">
                    <Grid ColumnDefinitions="250,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <Grid.Styles>
                            <Style Selector="TextBlock.label">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,8,8"/>
                            </Style>
                            <Style Selector="TextBox">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                            <Style Selector="NumericUpDown">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                            <Style Selector="ComboBox">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </Grid.Styles>
                        
                        

                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Пол:"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1"
                                   ItemsSource="{Binding GenderOptions}"
                                   SelectedIndex="{Binding GenderIndex}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Степень резекции:"/>
                        <ComboBox  Grid.Row="1" Grid.Column="1"
                                   ItemsSource="{Binding ResectionOptions}"
                                   SelectedIndex="{Binding ResectionIndex}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Локализация опухоли:"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1"
                                   ItemsSource="{Binding TumorLocationOptions}"
                                   SelectedIndex="{Binding TumorLocationIndex}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Стадия:"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                       Value="{Binding Stage}"
                                       Minimum="1" Maximum="4"
                                       Increment="1" FormatString="0.#"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Латерализация:"/>
                        <ComboBox  Grid.Row="4" Grid.Column="1"
                                   ItemsSource="{Binding LateralizationOptions}"
                                   SelectedIndex="{Binding LateralizationIndex}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Classes="label" Text="Ответ по RANO:"/>
                        <ComboBox  Grid.Row="5" Grid.Column="1"
                                   ItemsSource="{Binding RanoResponseOptions}"
                                   SelectedIndex="{Binding RanoResponseIndex}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="Контрастное усиление"/>
                        <ComboBox  Grid.Row="6" Grid.Column="1"
                                   ItemsSource="{Binding ContrastEnhancementOptions}"
                                   SelectedIndex="{Binding ContrastEnhancementIndex}"/>
                        
                        <CheckBox  Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="Семейный анамнез"
                                   IsChecked="{Binding FamilyHistory}" Margin="0,0,0,4"/>
                        <CheckBox  Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="Предшествующее облучение"
                                   IsChecked="{Binding PreviousRadiation}" Margin="0,0,0,4"/>
                    </Grid>
                </Border>

                <Border Height="8"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
